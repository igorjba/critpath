{
  "name": "critpath",
  "version": "0.1.0",
  "private": true,
  "description": "Turnaround maintenance optimizer: RCPSP scheduling, Monte Carlo start-date risk, and censored Weibull interval optimization — solved by a WASM engine in a Web Worker.",
  "scripts": {
    "predev": "npm run asbuild",
    "dev": "next dev",
    "prebuild": "npm run asbuild",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "asbuild": "asc --config asconfig.json --target release",
    "asbuild:debug": "asc --config asconfig.json --target debug",
    "validate": "node scripts/validate.mjs",
    "test": "vitest run",
    "pretest": "npm run asbuild"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/igorjba/critpath.git"
  },
  "license": "MIT",
  "dependencies": {
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "comlink": "^4.4.2",
    "d3-array": "^3.2.4",
    "d3-scale": "^4.0.2",
    "dexie": "^4.4.4",
    "lucide-react": "^1.25.0",
    "next": "^16.2.10",
    "papaparse": "^5.5.4",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.4.3",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@assemblyscript/loader": "^0.28.19",
    "@eslint/js": "^10.0.1",
    "@next/eslint-plugin-next": "^16.2.10",
    "@tailwindcss/postcss": "^4.3.3",
    "@types/d3-array": "^3.2.2",
    "@types/d3-scale": "^4.0.9",
    "@types/node": "^26.1.1",
    "@types/papaparse": "^5.5.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "assemblyscript": "^0.28.19",
    "eslint": "^10.7.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "tailwindcss": "^4.3.3",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.64.0",
    "vitest": "^4.1.10"
  },
  "overrides": {
    "postcss": "^8.5.19"
  }
}
