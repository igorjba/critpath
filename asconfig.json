{
  "entries": ["assembly/index.ts"],
  "targets": {
    "release": {
      "outFile": "public/wasm/critpath.wasm",
      "optimizeLevel": 3,
      "shrinkLevel": 0,
      "converge": true,
      "noAssert": true
    },
    "debug": {
      "outFile": "public/wasm/critpath.wasm",
      "debug": true
    }
  },
  "options": {
    "exportRuntime": true,
    "runtime": "incremental"
  }
}
